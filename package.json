{
  "name": "StorageAnalyse",
  "private": true,
  "type": "module",
  "version": "0.0.0",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --config electron.vite.config.mjs",
    "build": "electron-vite build --config electron.vite.config.mjs",
    "preview": "electron-vite preview",
    "lint": "eslint . --fix",
    "electron:build": "electron-vite build && electron-builder",
    "py": "cd back_end && uvicorn app:app --host 0.0.0.0 --port 8080 --reload",
    "py_prod": "cd back_end && python main_https.py"
  },
  "build": {
    "appId": "com.monapp.storageanalyzer",
    "productName": "StorageAnalyzer",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/python-embed",
        "to": "python-embed",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "python",
        "to": "python",
        "filter": [
          "*.py"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@fontsource/roboto": "5.2.7",
    "@mdi/font": "7.4.47",
    "pinia": "^3.0.3",
    "vue": "^3.5.21",
    "vue-router": "^4.5.1",
    "vuetify": "^3.10.1"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.28.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "autoprefixer": "^10.4.23",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^9.35.0",
    "eslint-config-vuetify": "^4.2.0",
    "postcss": "^8.5.6",
    "sass-embedded": "^1.92.1",
    "tailwindcss": "^3.4.19",
    "unplugin-auto-import": "^19.3.0",
    "unplugin-fonts": "^1.4.0",
    "unplugin-vue-components": "^29.2.0",
    "unplugin-vue-router": "^0.15.0",
    "vite": "^5.4.21",
    "vite-plugin-vue-layouts-next": "^1.3.0",
    "vite-plugin-vuetify": "^2.1.3"
  }
}
